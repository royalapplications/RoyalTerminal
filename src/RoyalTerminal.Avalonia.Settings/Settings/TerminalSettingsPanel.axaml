<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:settings="using:RoyalTerminal.Avalonia.Settings">
  <Styles.Resources>
    <ResourceDictionary>
      <ControlTheme x:Key="{x:Type settings:TerminalSettingsPanel}" TargetType="settings:TerminalSettingsPanel">
        <Setter Property="Template">
          <ControlTemplate TargetType="settings:TerminalSettingsPanel">
            <Border Width="720"
                    Height="700"
                    Padding="0"
                    Background="#252525"
                    BorderBrush="#4A4A4A"
                    BorderThickness="1"
                    CornerRadius="8"
                    ClipToBounds="True"
                    DataContext="{Binding DataContext, RelativeSource={RelativeSource TemplatedParent}}"
                    x:DataType="settings:TerminalSettingsPanelState">
              <Grid RowDefinitions="Auto,*,Auto">
                <Border Grid.Row="0"
                        Padding="18,14"
                        BorderBrush="#3A3A3A"
                        BorderThickness="0,0,0,1">
                  <Grid ColumnDefinitions="Auto,220,*"
                        RowDefinitions="Auto,Auto"
                        ColumnSpacing="12"
                        RowSpacing="8">
                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               VerticalAlignment="Center"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Text="Profile" />
                    <ComboBox Grid.Row="0"
                              Grid.Column="1"
                              MinHeight="34"
                              ItemsSource="{Binding Profiles}"
                              SelectedItem="{Binding SelectedProfile}">
                      <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="settings:TerminalSettingsProfileItem">
                          <TextBlock Text="{Binding DisplayName}" />
                        </DataTemplate>
                      </ComboBox.ItemTemplate>
                    </ComboBox>
                    <StackPanel Grid.Row="0"
                                Grid.Column="2"
                                VerticalAlignment="Center"
                                Orientation="Horizontal"
                                Spacing="16">
                      <TextBlock Foreground="#B8B8B8"
                                 Text="{Binding DefaultProfileId, StringFormat='Default: {0}'}" />
                      <TextBlock Foreground="#B8B8B8"
                                 IsVisible="{Binding IsDirty}"
                                 Text="Unsaved changes" />
                    </StackPanel>
                    <StackPanel Grid.Row="1"
                                Grid.Column="1"
                                Grid.ColumnSpan="2"
                                Orientation="Horizontal"
                                Spacing="8">
                      <Button Content="New"
                              MinWidth="72"
                              Command="{Binding NewProfileCommand}" />
                      <Button Content="Duplicate"
                              MinWidth="96"
                              Command="{Binding DuplicateProfileCommand}" />
                      <Button Content="Delete"
                              MinWidth="76"
                              Command="{Binding DeleteProfileCommand}" />
                      <Button Content="Set Default"
                              MinWidth="104"
                              Command="{Binding SetDefaultProfileCommand}" />
                    </StackPanel>
                  </Grid>
                </Border>

                <TabControl Grid.Row="1"
                            TabStripPlacement="Left"
                            Padding="0"
                            FontSize="14"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            ClipToBounds="True">
                  <TabControl.Styles>
                    <Style Selector="TabControl /template/ ContentPresenter#PART_SelectedContentHost">
                      <Setter Property="HorizontalAlignment" Value="Stretch" />
                      <Setter Property="VerticalAlignment" Value="Stretch" />
                      <Setter Property="ClipToBounds" Value="True" />
                    </Style>
                    <Style Selector="TabItem">
                      <Setter Property="MinWidth" Value="128" />
                      <Setter Property="MinHeight" Value="42" />
                      <Setter Property="Padding" Value="14,10" />
                      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                      <Setter Property="VerticalContentAlignment" Value="Stretch" />
                      <Setter Property="FontSize" Value="14" />
                    </Style>
                  </TabControl.Styles>
                  <TabItem Header="Session">
                    <ScrollViewer Classes="settings-tab-scroll"
                                  AllowAutoHide="False"
                                  Padding="20,16"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  ClipToBounds="True"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
                      <settings:TerminalSettingsSessionPanel DataContext="{Binding Session}" />
                    </ScrollViewer>
                  </TabItem>

                  <TabItem Header="Connection">
                    <ScrollViewer Classes="settings-tab-scroll"
                                  AllowAutoHide="False"
                                  Padding="20,16"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  ClipToBounds="True"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
                      <settings:TerminalSettingsConnectionPanel
                        DataContext="{Binding Connection}" />
                    </ScrollViewer>
                  </TabItem>

                  <TabItem Header="Terminal">
                    <ScrollViewer Classes="settings-tab-scroll"
                                  AllowAutoHide="False"
                                  Padding="20,16"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  ClipToBounds="True"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
                      <settings:TerminalSettingsTerminalPanel
                        DataContext="{Binding TerminalBehavior}" />
                    </ScrollViewer>
                  </TabItem>

                  <TabItem Header="Appearance">
                    <ScrollViewer Classes="settings-tab-scroll"
                                  AllowAutoHide="False"
                                  Padding="20,16"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  ClipToBounds="True"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
                      <settings:TerminalSettingsAppearancePanel
                        DataContext="{Binding Appearance}" />
                    </ScrollViewer>
                  </TabItem>

                  <TabItem Header="SSH">
                    <ScrollViewer Classes="settings-tab-scroll"
                                  AllowAutoHide="False"
                                  Padding="20,16"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  ClipToBounds="True"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
                      <settings:TerminalSettingsSshPanel DataContext="{Binding Ssh}" />
                    </ScrollViewer>
                  </TabItem>

                  <TabItem Header="Logging">
                    <ScrollViewer Classes="settings-tab-scroll"
                                  AllowAutoHide="False"
                                  Padding="20,16"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  ClipToBounds="True"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
                      <settings:TerminalSettingsLoggingPanel DataContext="{Binding Logging}" />
                    </ScrollViewer>
                  </TabItem>
                </TabControl>

                <Border Grid.Row="2"
                        Padding="18,12"
                        BorderBrush="#3A3A3A"
                        BorderThickness="0,1,0,0">
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                    <TextBlock Grid.Column="0"
                               VerticalAlignment="Center"
                               Foreground="#B8B8B8"
                               Text="{Binding LastOperationStatus}" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                      <Button Content="Apply"
                              MinWidth="84"
                              Command="{Binding ApplyCommand}" />
                      <Button Content="Save"
                              MinWidth="84"
                              Command="{Binding SaveCommand}" />
                    </StackPanel>
                  </Grid>
                </Border>
              </Grid>
            </Border>
          </ControlTemplate>
        </Setter>
      </ControlTheme>

      <ControlTheme x:Key="{x:Type settings:TerminalSettingsSessionPanel}"
                    TargetType="settings:TerminalSettingsSessionPanel">
        <Setter Property="Template">
          <ControlTemplate TargetType="settings:TerminalSettingsSessionPanel">
            <StackPanel
              DataContext="{Binding DataContext, RelativeSource={RelativeSource TemplatedParent}}"
              x:DataType="settings:TerminalSettingsSessionState"
              Spacing="12"
              Margin="0,10,0,0">
              <StackPanel Spacing="4">
                <TextBlock Text="Session Name" Margin="0,4,6,0" />
                <TextBox Text="{Binding SessionName}" />
              </StackPanel>
              <StackPanel Spacing="4">
                <TextBlock Text="Transport" Margin="0,4,6,0" />
                <ComboBox
                  ItemsSource="{Binding TransportModes}"
                  SelectedItem="{Binding SelectedTransportMode}">
                  <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="settings:TerminalSettingsTransportModeOption">
                      <TextBlock Text="{Binding DisplayName}" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
              </StackPanel>
            </StackPanel>
          </ControlTemplate>
        </Setter>
      </ControlTheme>

      <ControlTheme x:Key="{x:Type settings:TerminalSettingsConnectionPanel}"
                    TargetType="settings:TerminalSettingsConnectionPanel">
        <Setter Property="Template">
          <ControlTemplate TargetType="settings:TerminalSettingsConnectionPanel">
            <StackPanel
              DataContext="{Binding DataContext, RelativeSource={RelativeSource TemplatedParent}}"
              x:DataType="settings:TerminalSettingsConnectionState"
              Spacing="12"
              Margin="0,10,0,0">
              <TextBlock Text="PTY / Pipe" FontWeight="Bold" />
              <StackPanel Spacing="4">
                <TextBlock Text="Working Dir" Margin="0,4,6,0" />
                <TextBox Margin="0,0,8,0" Text="{Binding WorkingDirectory}" />
                <TextBlock Text="Shell Path" Margin="0,4,6,0" />
                <TextBox Text="{Binding ShellPath}" />
              </StackPanel>
              <StackPanel Spacing="4">
                <TextBlock Text="Pipe Cmd" Margin="0,4,6,0" />
                <TextBox Margin="0,0,8,0" Text="{Binding PipeCommandText}" />
                <CheckBox Content="Merge stderr"
                          Margin="0,2,0,0"
                          IsChecked="{Binding PipeMergeStdErrIntoStdOut}" />
              </StackPanel>

              <TextBlock Text="Raw TCP" FontWeight="Bold" />
              <StackPanel Spacing="4">
                <TextBlock Text="Host" Margin="0,4,6,0" />
                <TextBox Margin="0,0,8,0" Text="{Binding RawTcpHost}" />
                <TextBlock Text="Port" Margin="0,4,6,0" />
                <TextBox Text="{Binding RawTcpPort}" />
              </StackPanel>

              <TextBlock Text="Telnet" FontWeight="Bold" />
              <StackPanel Spacing="4">
                <TextBlock Text="Host" Margin="0,4,6,0" />
                <TextBox Margin="0,0,8,0" Text="{Binding TelnetHost}" />
                <TextBlock Text="Port" Margin="0,4,6,0" />
                <TextBox Margin="0,0,8,0" Text="{Binding TelnetPort}" />
                <TextBlock Text="Terminal" Margin="0,4,6,0" />
                <TextBox Text="{Binding TelnetTerminalType}" />
              </StackPanel>
              <StackPanel Spacing="4">
                <TextBlock Text="Initial Cmd" Margin="0,4,6,0" />
                <TextBox Text="{Binding TelnetInitialCommand}" />
              </StackPanel>

              <TextBlock Text="Serial" FontWeight="Bold" />
              <StackPanel Spacing="4">
                <TextBlock Text="Port" Margin="0,4,6,0" />
                <TextBox Margin="0,0,8,0" Text="{Binding SerialPortName}" />
                <TextBlock Text="Baud" Margin="0,4,6,0" />
                <TextBox Margin="0,0,8,0" Text="{Binding SerialBaudRate}" />
                <TextBlock Text="Data Bits" Margin="0,4,6,0" />
                <TextBox Margin="0,0,8,0" Text="{Binding SerialDataBits}" />
                <TextBlock Text="NewLine" Margin="0,4,6,0" />
                <TextBox Text="{Binding SerialNewLine}" />
              </StackPanel>
              <StackPanel Spacing="4">
                <TextBlock Text="Parity" Margin="0,4,6,0" />
                <ComboBox
                  Margin="0,0,8,0"
                  ItemsSource="{Binding SerialParityOptions}"
                  SelectedItem="{Binding SelectedSerialParity}" />
                <TextBlock Text="Stop Bits" Margin="0,4,6,0" />
                <ComboBox
                  Margin="0,0,8,0"
                  ItemsSource="{Binding SerialStopBitsOptions}"
                  SelectedItem="{Binding SelectedSerialStopBits}" />
                <TextBlock Text="Handshake" Margin="0,4,6,0" />
                <ComboBox
                  ItemsSource="{Binding SerialHandshakeOptions}"
                  SelectedItem="{Binding SelectedSerialHandshake}" />
              </StackPanel>

              <TextBlock Text="SSH Endpoint" FontWeight="Bold" />
              <StackPanel Spacing="4">
                <TextBlock Text="Host" Margin="0,4,6,0" />
                <TextBox Margin="0,0,8,0" Text="{Binding SshHost}" />
                <TextBlock Text="Port" Margin="0,4,6,0" />
                <TextBox Margin="0,0,8,0" Text="{Binding SshPort}" />
                <TextBlock Text="User" Margin="0,4,6,0" />
                <TextBox Text="{Binding SshUsername}" />
              </StackPanel>
            </StackPanel>
          </ControlTemplate>
        </Setter>
      </ControlTheme>

      <ControlTheme x:Key="{x:Type settings:TerminalSettingsTerminalPanel}"
                    TargetType="settings:TerminalSettingsTerminalPanel">
        <Setter Property="Template">
          <ControlTemplate TargetType="settings:TerminalSettingsTerminalPanel">
            <StackPanel
              DataContext="{Binding DataContext, RelativeSource={RelativeSource TemplatedParent}}"
              x:DataType="settings:TerminalSettingsTerminalBehaviorState"
              Spacing="12"
              Margin="0,10,0,0">
              <StackPanel Spacing="4">
                <CheckBox Content="Copy on Select"
                          Margin="0,2,10,0"
                          IsChecked="{Binding CopyOnSelectEnabled}" />
                <CheckBox Content="Bell Notifications"
                          Margin="0,2,10,0"
                          IsChecked="{Binding EnableBellNotifications}" />
                <CheckBox Content="Backspace sends Ctrl-H"
                          Margin="0,2,10,0"
                          IsChecked="{Binding BackspaceSendsControlH}" />
              </StackPanel>
              <StackPanel Spacing="4">
                <CheckBox Content="Enable Text Shaping"
                          Margin="0,2,10,0"
                          IsChecked="{Binding EnableTextShaping}" />
                <CheckBox Content="Reflow on Resize"
                          Margin="0,2,10,0"
                          IsChecked="{Binding ReflowOnResize}" />
                <CheckBox Content="Enable Sixel Graphics"
                          Margin="0,2,10,0"
                          IsChecked="{Binding SixelGraphicsEnabled}" />
                <CheckBox Content="Enable Ligatures"
                          Margin="0,2,10,0"
                          IsChecked="{Binding EnableLigatures}" />
                <TextBlock Text="Paste Safety" Margin="0,4,6,0" />
                <ComboBox
                  ItemsSource="{Binding PasteSafetyPolicies}"
                  SelectedItem="{Binding SelectedPasteSafetyPolicy}" />
              </StackPanel>
              <StackPanel Spacing="4">
                <CheckBox Content="SSH Request PTY"
                          Margin="0,2,10,0"
                          IsChecked="{Binding SshRequestPty}" />
                <TextBlock Text="SSH Terminal" Margin="0,4,6,0" />
                <TextBox Margin="0,0,8,0" Text="{Binding SshTerminalType}" />
                <TextBlock Text="SSH Initial Cmd" Margin="0,4,6,0" />
                <TextBox Text="{Binding SshInitialCommand}" />
              </StackPanel>
              <StackPanel Spacing="4">
                <TextBlock Text="Telnet Terminal" Margin="0,4,6,0" />
                <TextBox Margin="0,0,8,0" Text="{Binding TelnetTerminalType}" />
                <TextBlock Text="Telnet Initial Cmd" Margin="0,4,6,0" />
                <TextBox Text="{Binding TelnetInitialCommand}" />
              </StackPanel>
            </StackPanel>
          </ControlTemplate>
        </Setter>
      </ControlTheme>

      <ControlTheme x:Key="{x:Type settings:TerminalSettingsAppearancePanel}"
                    TargetType="settings:TerminalSettingsAppearancePanel">
        <Setter Property="Template">
          <ControlTemplate TargetType="settings:TerminalSettingsAppearancePanel">
            <StackPanel
              DataContext="{Binding DataContext, RelativeSource={RelativeSource TemplatedParent}}"
              x:DataType="settings:TerminalSettingsAppearanceState"
              HorizontalAlignment="Left"
              Width="520"
              Spacing="20">
              <StackPanel Spacing="10">
                <TextBlock Text="Typography"
                           FontSize="16"
                           FontWeight="SemiBold" />
                <Grid ColumnDefinitions="118,*"
                      RowDefinitions="Auto,Auto,Auto,Auto"
                      ColumnSpacing="12"
                      RowSpacing="10"
                      Width="520">
                  <TextBlock Grid.Row="0"
                             Grid.Column="0"
                             VerticalAlignment="Center"
                             Foreground="#B8B8B8"
                             Text="Font source" />
                  <ComboBox Grid.Row="0"
                            Grid.Column="1"
                            Width="240"
                            HorizontalAlignment="Left"
                            ItemsSource="{Binding FontSources}"
                            SelectedValue="{Binding SelectedFontSource}"
                            SelectedValueBinding="{Binding Source}">
                    <ComboBox.ItemTemplate>
                      <DataTemplate x:DataType="settings:TerminalSettingsFontSourceOption">
                        <TextBlock Text="{Binding DisplayName}" />
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>

                  <TextBlock Grid.Row="1"
                             Grid.Column="0"
                             VerticalAlignment="Center"
                             Foreground="#B8B8B8"
                             Text="System font"
                             IsVisible="{Binding IsSystemFontSourceSelected}" />
                  <ComboBox Grid.Row="1"
                            Grid.Column="1"
                            Width="240"
                            HorizontalAlignment="Left"
                            ItemsSource="{Binding SystemFontFamilies}"
                            SelectedItem="{Binding FontFamilyName}"
                            IsVisible="{Binding IsSystemFontSourceSelected}" />

                  <TextBlock Grid.Row="2"
                             Grid.Column="0"
                             VerticalAlignment="Center"
                             Foreground="#B8B8B8"
                             Text="Font file"
                             IsVisible="{Binding IsFileFontSourceSelected}" />
                  <Grid Grid.Row="2"
                        Grid.Column="1"
                        Width="390"
                        HorizontalAlignment="Left"
                        ColumnDefinitions="*,Auto"
                        ColumnSpacing="8"
                        IsVisible="{Binding IsFileFontSourceSelected}">
                    <TextBox Grid.Column="0"
                             IsReadOnly="True"
                             Text="{Binding FontFilePath}" />
                    <Button Grid.Column="1"
                            Content="Browse"
                            Command="{Binding BrowseFontFileCommand}" />
                  </Grid>

                  <TextBlock Grid.Row="3"
                             Grid.Column="0"
                             VerticalAlignment="Center"
                             Foreground="#B8B8B8"
                             Text="Font size" />
                  <NumericUpDown Grid.Row="3"
                                 Grid.Column="1"
                                 Width="160"
                                 HorizontalAlignment="Left"
                                 Minimum="8"
                                 Maximum="72"
                                 Increment="1"
                                 Value="{Binding FontSize}" />
                </Grid>
                <TextBlock Foreground="#9F9F9F"
                           IsVisible="{Binding IsFileFontSourceSelected}"
                           Text="{Binding FontFamilyName, StringFormat='Resolved family: {0}'}" />
              </StackPanel>

              <StackPanel Spacing="10">
                <TextBlock Text="Behavior"
                           FontSize="16"
                           FontWeight="SemiBold" />
                <WrapPanel Orientation="Horizontal">
                  <CheckBox Content="Auto scroll"
                            Margin="0,0,24,0"
                            IsChecked="{Binding AutoScroll}" />
                  <CheckBox Content="Background opacity"
                            IsChecked="{Binding BackgroundOpacityEnabled}" />
                </WrapPanel>
              </StackPanel>

              <StackPanel Spacing="12">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                  <StackPanel Grid.Column="0">
                    <TextBlock Text="Text Highlighting"
                               FontSize="16"
                               FontWeight="SemiBold" />
                  </StackPanel>
                  <Button Grid.Column="1"
                          Content="Add Rule"
                          MinWidth="96"
                          Command="{Binding AddTextHighlightRuleCommand}" />
                </Grid>

                <Grid ColumnDefinitions="118,*"
                      ColumnSpacing="12"
                      Width="520">
                  <TextBlock Grid.Column="0"
                             VerticalAlignment="Center"
                             Foreground="#B8B8B8"
                             Text="Evaluation" />
                  <ComboBox Grid.Column="1"
                            Width="220"
                            HorizontalAlignment="Left"
                            ItemsSource="{Binding TextHighlightingModes}"
                            SelectedItem="{Binding SelectedTextHighlightingMode}">
                    <ComboBox.ItemTemplate>
                      <DataTemplate x:DataType="settings:TerminalSettingsTextHighlightingModeOption">
                        <TextBlock Text="{Binding DisplayName}" />
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                </Grid>

                <ItemsControl ItemsSource="{Binding TextHighlightRules}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="settings:TerminalSettingsHighlightRuleState">
                      <Border BorderBrush="#505050"
                              BorderThickness="1"
                              CornerRadius="6"
                              Padding="12"
                              Margin="0,0,0,10">
                        <Grid RowDefinitions="Auto,Auto,Auto"
                              RowSpacing="10">
                          <Grid Grid.Row="0"
                                ColumnDefinitions="Auto,*,Auto"
                                ColumnSpacing="12">
                            <CheckBox Grid.Column="0"
                                      VerticalAlignment="Center"
                                      Content="Enabled"
                                      IsChecked="{Binding IsEnabled}" />
                            <TextBox Grid.Column="1"
                                     PlaceholderText="Rule name"
                                     Text="{Binding Name}" />
                            <Button Grid.Column="2"
                                    Content="Remove"
                                    MinWidth="82"
                                    Command="{Binding RemoveCommand}" />
                          </Grid>

                          <Grid Grid.Row="1"
                                ColumnDefinitions="86,*"
                                ColumnSpacing="12">
                            <TextBlock Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Foreground="#B8B8B8"
                                       Text="Regex" />
                            <TextBox Grid.Column="1"
                                     PlaceholderText="\b(ERROR|WARN)\b"
                                     Text="{Binding Pattern}" />
                          </Grid>

                          <Grid Grid.Row="2"
                                ColumnDefinitions="*,*"
                                RowDefinitions="Auto,Auto"
                                ColumnSpacing="12"
                                RowSpacing="10">
                            <Grid Grid.Row="0"
                                  Grid.Column="0"
                                  ColumnDefinitions="Auto,*"
                                  ColumnSpacing="8">
                              <CheckBox Grid.Column="0"
                                        VerticalAlignment="Center"
                                        Content="Foreground"
                                        IsChecked="{Binding IsForegroundEnabled}" />
                              <TextBox Grid.Column="1"
                                       PlaceholderText="#FFFFFFFF"
                                       Text="{Binding ForegroundColor}"
                                       IsEnabled="{Binding IsForegroundEnabled}" />
                            </Grid>
                            <Grid Grid.Row="0"
                                  Grid.Column="1"
                                  ColumnDefinitions="Auto,*"
                                  ColumnSpacing="8">
                              <CheckBox Grid.Column="0"
                                        VerticalAlignment="Center"
                                        Content="Background"
                                        IsChecked="{Binding IsBackgroundEnabled}" />
                              <TextBox Grid.Column="1"
                                       PlaceholderText="#FF000000"
                                       Text="{Binding BackgroundColor}"
                                       IsEnabled="{Binding IsBackgroundEnabled}" />
                            </Grid>
                            <Grid Grid.Row="1"
                                  Grid.Column="0"
                                  ColumnDefinitions="Auto,*"
                                  ColumnSpacing="8">
                              <CheckBox Grid.Column="0"
                                        VerticalAlignment="Center"
                                        Content="Dark foreground"
                                        IsChecked="{Binding IsDarkForegroundEnabled}" />
                              <TextBox Grid.Column="1"
                                       PlaceholderText="#FFFFFFFF"
                                       Text="{Binding DarkForegroundColor}"
                                       IsEnabled="{Binding IsDarkForegroundEnabled}" />
                            </Grid>
                            <Grid Grid.Row="1"
                                  Grid.Column="1"
                                  ColumnDefinitions="Auto,*"
                                  ColumnSpacing="8">
                              <CheckBox Grid.Column="0"
                                        VerticalAlignment="Center"
                                        Content="Dark background"
                                        IsChecked="{Binding IsDarkBackgroundEnabled}" />
                              <TextBox Grid.Column="1"
                                       PlaceholderText="#FF000000"
                                       Text="{Binding DarkBackgroundColor}"
                                       IsEnabled="{Binding IsDarkBackgroundEnabled}" />
                            </Grid>
                          </Grid>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </StackPanel>
          </ControlTemplate>
        </Setter>
      </ControlTheme>

      <ControlTheme x:Key="{x:Type settings:TerminalSettingsSshPanel}"
                    TargetType="settings:TerminalSettingsSshPanel">
        <Setter Property="Template">
          <ControlTemplate TargetType="settings:TerminalSettingsSshPanel">
            <StackPanel
              DataContext="{Binding DataContext, RelativeSource={RelativeSource TemplatedParent}}"
              x:DataType="settings:TerminalSettingsSshState"
              Spacing="12"
              Margin="0,10,0,0">
              <StackPanel Spacing="4">
                <TextBlock Text="Auth" Margin="0,4,6,0" />
                <ComboBox
                  Margin="0,0,8,0"
                  ItemsSource="{Binding SshAuthModes}"
                  SelectedItem="{Binding SelectedSshAuthMode}">
                  <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="settings:TerminalSettingsSshAuthModeOption">
                      <TextBlock Text="{Binding DisplayName}" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
                <TextBlock Text="Password" Margin="0,4,6,0" />
                <TextBox Margin="0,0,8,0" PasswordChar="*" Text="{Binding SshPassword}" />
                <TextBlock Text="Private Key(s)" Margin="0,4,6,0" />
                <TextBox Text="{Binding SshPrivateKeyPath}" />
              </StackPanel>

              <StackPanel Spacing="4">
                <TextBlock Text="Host Key SHA256" Margin="0,4,6,0" />
                <TextBox Text="{Binding SshExpectedHostKeyFingerprintSha256}" />
              </StackPanel>

              <TextBlock Text="Proxy" FontWeight="Bold" />
              <StackPanel Spacing="4">
                <TextBlock Text="Type" Margin="0,4,6,0" />
                <ComboBox
                  Margin="0,0,8,0"
                  ItemsSource="{Binding SshProxyTypes}"
                  SelectedItem="{Binding SelectedSshProxyType}" />
                <TextBlock Text="Host" Margin="0,4,6,0" />
                <TextBox Margin="0,0,8,0" Text="{Binding SshProxyHost}" />
                <TextBlock Text="Port" Margin="0,4,6,0" />
                <TextBox Margin="0,0,8,0" Text="{Binding SshProxyPort}" />
                <TextBlock Text="User" Margin="0,4,6,0" />
                <TextBox Margin="0,0,8,0" Text="{Binding SshProxyUsername}" />
                <TextBlock Text="Password" Margin="0,4,6,0" />
                <TextBox PasswordChar="*" Text="{Binding SshProxyPassword}" />
              </StackPanel>

              <TextBlock Text="Local Port Forward" FontWeight="Bold" />
              <StackPanel Spacing="4">
                <CheckBox Content="Enabled"
                          Margin="0,2,8,0"
                          IsChecked="{Binding SshLocalPortForwardEnabled}" />
                <TextBlock Text="Bind" Margin="0,4,6,0" />
                <TextBox Margin="0,0,8,0" Text="{Binding SshLocalPortForwardBindAddress}" />
                <TextBlock Text="Source" Margin="0,4,6,0" />
                <TextBox Margin="0,0,8,0" Text="{Binding SshLocalPortForwardSourcePort}" />
                <TextBlock Text="Dest Host" Margin="0,4,6,0" />
                <TextBox Margin="0,0,8,0" Text="{Binding SshLocalPortForwardDestinationHost}" />
                <TextBlock Text="Dest Port" Margin="0,4,6,0" />
                <TextBox Text="{Binding SshLocalPortForwardDestinationPort}" />
              </StackPanel>

              <TextBlock Text="X11 / Policy" FontWeight="Bold" />
              <StackPanel Spacing="4">
                <CheckBox Content="Enable X11"
                          Margin="0,2,8,0"
                          IsChecked="{Binding SshX11Enabled}" />
                <TextBlock Text="Display" Margin="0,4,6,0" />
                <TextBox Margin="0,0,8,0" Text="{Binding SshX11Display}" />
                <TextBlock Text="KeepAlive (s)" Margin="0,4,6,0" />
                <TextBox Margin="0,0,8,0" Text="{Binding SshKeepAliveIntervalSeconds}" />
                <TextBlock Text="Connect Timeout (s)" Margin="0,4,6,0" />
                <TextBox Text="{Binding SshConnectTimeoutSeconds}" />
              </StackPanel>
            </StackPanel>
          </ControlTemplate>
        </Setter>
      </ControlTheme>

      <ControlTheme x:Key="{x:Type settings:TerminalSettingsLoggingPanel}"
                    TargetType="settings:TerminalSettingsLoggingPanel">
        <Setter Property="Template">
          <ControlTemplate TargetType="settings:TerminalSettingsLoggingPanel">
            <StackPanel
              DataContext="{Binding DataContext, RelativeSource={RelativeSource TemplatedParent}}"
              x:DataType="settings:TerminalSettingsLoggingState"
              Spacing="12"
              Margin="0,10,0,0">
              <StackPanel Spacing="4">
                <CheckBox Content="Enable Session Log"
                          Margin="0,2,10,0"
                          IsChecked="{Binding SessionLoggingEnabled}" />
                <TextBlock Text="Format" Margin="0,4,6,0" />
                <ComboBox
                  Margin="0,0,8,0"
                  ItemsSource="{Binding SessionLogFormats}"
                  SelectedItem="{Binding SelectedSessionLogFormat}" />
                <CheckBox Content="Flush Frequently"
                          Margin="0,2,10,0"
                          IsChecked="{Binding SessionLogFlushFrequently}" />
                <CheckBox Content="Enable Event Log"
                          Margin="0,2,10,0"
                          IsChecked="{Binding EventLogEnabled}" />
              </StackPanel>
              <StackPanel Spacing="4">
                <TextBlock Text="Session Log File" Margin="0,4,6,0" />
                <TextBox Text="{Binding SessionLogFilePath}" />
              </StackPanel>
            </StackPanel>
          </ControlTemplate>
        </Setter>
      </ControlTheme>
    </ResourceDictionary>
  </Styles.Resources>

  <Style Selector="settings|TerminalSettingsPanel">
    <Setter Property="Theme" Value="{StaticResource {x:Type settings:TerminalSettingsPanel}}" />
  </Style>

  <Style Selector="settings|TerminalSettingsPanel TextBlock">
    <Setter Property="FontSize" Value="14" />
  </Style>

  <Style Selector="settings|TerminalSettingsPanel Button">
    <Setter Property="FontSize" Value="14" />
  </Style>

  <Style Selector="settings|TerminalSettingsPanel ComboBox">
    <Setter Property="FontSize" Value="14" />
  </Style>

  <Style Selector="settings|TerminalSettingsPanel TextBox">
    <Setter Property="FontSize" Value="14" />
  </Style>

  <Style Selector="settings|TerminalSettingsPanel CheckBox">
    <Setter Property="FontSize" Value="14" />
  </Style>

  <Style Selector="settings|TerminalSettingsPanel NumericUpDown">
    <Setter Property="FontSize" Value="14" />
  </Style>

  <Style Selector="settings|TerminalSettingsPanel ScrollViewer.settings-tab-scroll">
    <Setter Property="AllowAutoHide" Value="False" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="VerticalAlignment" Value="Stretch" />
    <Setter Property="ClipToBounds" Value="True" />
    <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
    <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
  </Style>

  <Style Selector="settings|TerminalSettingsSessionPanel">
    <Setter Property="Theme" Value="{StaticResource {x:Type settings:TerminalSettingsSessionPanel}}" />
  </Style>

  <Style Selector="settings|TerminalSettingsConnectionPanel">
    <Setter Property="Theme" Value="{StaticResource {x:Type settings:TerminalSettingsConnectionPanel}}" />
  </Style>

  <Style Selector="settings|TerminalSettingsTerminalPanel">
    <Setter Property="Theme" Value="{StaticResource {x:Type settings:TerminalSettingsTerminalPanel}}" />
  </Style>

  <Style Selector="settings|TerminalSettingsAppearancePanel">
    <Setter Property="Theme" Value="{StaticResource {x:Type settings:TerminalSettingsAppearancePanel}}" />
  </Style>

  <Style Selector="settings|TerminalSettingsSshPanel">
    <Setter Property="Theme" Value="{StaticResource {x:Type settings:TerminalSettingsSshPanel}}" />
  </Style>

  <Style Selector="settings|TerminalSettingsLoggingPanel">
    <Setter Property="Theme" Value="{StaticResource {x:Type settings:TerminalSettingsLoggingPanel}}" />
  </Style>
</Styles>
