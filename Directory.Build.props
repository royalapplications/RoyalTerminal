<Project>
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
    <AnalysisLevel>latest</AnalysisLevel>
    <VersionPrefix>0.1.0</VersionPrefix>
    <VersionSuffix></VersionSuffix>
  </PropertyGroup>

  <PropertyGroup>
    <Authors>Royal Apps Contributors</Authors>
    <Company>Royal Apps</Company>
    <Copyright>Copyright © 2026 Royal Apps Contributors</Copyright>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/ghostty-org/ghostty</PackageProjectUrl>
    <RepositoryUrl>https://github.com/ghostty-org/ghostty</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageTags>ghostty;terminal;vte;pty;bindings;interop</PackageTags>
  </PropertyGroup>
</Project>
