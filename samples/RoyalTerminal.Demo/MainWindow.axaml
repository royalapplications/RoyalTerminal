<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RoyalTerminal.Demo.ViewModels"
        x:Class="RoyalTerminal.Demo.MainWindow"
        x:Name="RootWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="RoyalTerminal Terminal"
        Width="1024" Height="768"
        MinWidth="400" MinHeight="300"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+T" Command="{Binding NewTabCommand}" />
        <KeyBinding Gesture="Ctrl+W" Command="{Binding CloseCurrentTabCommand}" />
        <KeyBinding Gesture="Ctrl+Tab" Command="{Binding CycleTabForwardCommand}" />
        <KeyBinding Gesture="Ctrl+Shift+Tab" Command="{Binding CycleTabBackwardCommand}" />
        <KeyBinding Gesture="Ctrl+Add" Command="{Binding IncreaseFontSizeCommand}" />
        <KeyBinding Gesture="Ctrl+OemPlus" Command="{Binding IncreaseFontSizeCommand}" />
        <KeyBinding Gesture="Ctrl+Subtract" Command="{Binding DecreaseFontSizeCommand}" />
        <KeyBinding Gesture="Ctrl+OemMinus" Command="{Binding DecreaseFontSizeCommand}" />
        <KeyBinding Gesture="Ctrl+D0" Command="{Binding ResetFontSizeCommand}" />
        <KeyBinding Gesture="Ctrl+Shift+R" Command="{Binding ToggleRenderedBackendCommand}" />
        <KeyBinding Gesture="Ctrl+Shift+C" Command="{Binding CopySelectionCommand}" />
        <KeyBinding Gesture="Ctrl+Shift+V" Command="{Binding PasteClipboardCommand}" />
        <KeyBinding Gesture="Ctrl+D1" Command="{Binding SwitchToTabByIndexCommand}" CommandParameter="0" />
        <KeyBinding Gesture="Ctrl+D2" Command="{Binding SwitchToTabByIndexCommand}" CommandParameter="1" />
        <KeyBinding Gesture="Ctrl+D3" Command="{Binding SwitchToTabByIndexCommand}" CommandParameter="2" />
        <KeyBinding Gesture="Ctrl+D4" Command="{Binding SwitchToTabByIndexCommand}" CommandParameter="3" />
        <KeyBinding Gesture="Ctrl+D5" Command="{Binding SwitchToTabByIndexCommand}" CommandParameter="4" />
        <KeyBinding Gesture="Ctrl+D6" Command="{Binding SwitchToTabByIndexCommand}" CommandParameter="5" />
        <KeyBinding Gesture="Ctrl+D7" Command="{Binding SwitchToTabByIndexCommand}" CommandParameter="6" />
        <KeyBinding Gesture="Ctrl+D8" Command="{Binding SwitchToTabByIndexCommand}" CommandParameter="7" />
        <KeyBinding Gesture="Ctrl+D9" Command="{Binding SwitchToTabByIndexCommand}" CommandParameter="8" />
    </Window.KeyBindings>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="{DynamicResource ToolbarBackgroundBrush}" Padding="4,2">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="4"
                            VerticalAlignment="Center">
                    <Button Content="A-" Width="28" Height="24"
                            FontSize="10" Padding="2"
                            Command="{Binding DecreaseFontSizeCommand}"
                            ToolTip.Tip="Decrease font size (Ctrl+-)" />
                    <TextBlock Text="{Binding FontSizeDisplay}" VerticalAlignment="Center"
                               Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" Width="24"
                               TextAlignment="Center" />
                    <Button Content="A+" Width="28" Height="24"
                            FontSize="10" Padding="2"
                            Command="{Binding IncreaseFontSizeCommand}"
                            ToolTip.Tip="Increase font size (Ctrl++)" />
                    <Border Width="1" Background="{StaticResource ToolbarDividerBrush}" Margin="4,2" />
                    <Button Content="{Binding ThemeToggleContent}" Width="28" Height="24"
                            FontSize="12" Padding="2"
                            Command="{Binding ToggleThemeCommand}"
                            ToolTip.Tip="Toggle light/dark theme" />
                    <Border Width="1" Background="{StaticResource ToolbarDividerBrush}" Margin="4,2" />
                    <Button Content="{Binding ModeButtonText}" Height="24"
                            FontSize="10" Padding="8,2"
                            Command="{Binding CycleRenderModeCommand}"
                            ToolTip.Tip="Switch rendering mode (Ghostty Rendered / Ghostty Native / Native VT / Rendered)" />
                    <Button Content="{Binding RenderedBackendButtonText}" Height="24"
                            FontSize="10" Padding="8,2"
                            Command="{Binding ToggleRenderedBackendCommand}"
                            ToolTip.Tip="Toggle Ghostty rendered backend (TextureInterop / CPU Cell Renderer)" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <Button Content="+ New Tab" Height="24"
                            FontSize="11" Padding="8,2"
                            Command="{Binding NewTabCommand}"
                            ToolTip.Tip="New terminal tab (Ctrl+T)" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Border DockPanel.Dock="Top" Background="{DynamicResource TabStripBackgroundBrush}" Padding="4,2,4,0">
            <StackPanel Name="TabStrip" Orientation="Horizontal" Spacing="2" />
        </Border>

        <Border DockPanel.Dock="Bottom" Background="{DynamicResource StatusBarBackgroundBrush}" Padding="8,2" Height="24">
            <DockPanel>
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding DimensionsText}"
                           Foreground="{DynamicResource StatusBarForegroundBrush}" FontSize="11"
                           VerticalAlignment="Center" />
                <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource StatusBarForegroundBrush}"
                           FontSize="11" VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <Grid Name="TerminalHost" />
    </DockPanel>

    <Window.ContextMenu>
        <ContextMenu x:DataType="vm:MainWindowViewModel"
                     DataContext="{Binding #RootWindow.DataContext}">
            <MenuItem Header="_Copy" InputGesture="Ctrl+Shift+C" Command="{Binding CopySelectionCommand}" />
            <MenuItem Header="_Paste" InputGesture="Ctrl+Shift+V" Command="{Binding PasteClipboardCommand}" />
            <Separator />
            <MenuItem Header="Select _All" InputGesture="Ctrl+Shift+A" IsEnabled="False" />
            <Separator />
            <MenuItem Header="_New Tab" InputGesture="Ctrl+T" Command="{Binding NewTabCommand}" />
            <MenuItem Header="C_lose Tab" InputGesture="Ctrl+W" Command="{Binding CloseCurrentTabCommand}" />
        </ContextMenu>
    </Window.ContextMenu>

</Window>
