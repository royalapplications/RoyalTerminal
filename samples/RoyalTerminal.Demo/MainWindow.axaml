<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RoyalTerminal.Demo.ViewModels"
        xmlns:settings="using:RoyalTerminal.Avalonia.Settings"
        x:Class="RoyalTerminal.Demo.MainWindow"
        x:Name="RootWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="RoyalTerminal Terminal"
        Width="1024" Height="768"
        MinWidth="400" MinHeight="300"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}">

  <Window.KeyBindings>
    <KeyBinding Gesture="Ctrl+T" Command="{Binding NewTabCommand}" />
    <KeyBinding Gesture="Ctrl+W" Command="{Binding CloseCurrentTabCommand}" />
    <KeyBinding Gesture="Ctrl+Tab" Command="{Binding CycleTabForwardCommand}" />
    <KeyBinding Gesture="Ctrl+Shift+Tab" Command="{Binding CycleTabBackwardCommand}" />
    <KeyBinding Gesture="Ctrl+Add" Command="{Binding IncreaseFontSizeCommand}" />
    <KeyBinding Gesture="Ctrl+OemPlus" Command="{Binding IncreaseFontSizeCommand}" />
    <KeyBinding Gesture="Ctrl+Subtract" Command="{Binding DecreaseFontSizeCommand}" />
    <KeyBinding Gesture="Ctrl+OemMinus" Command="{Binding DecreaseFontSizeCommand}" />
    <KeyBinding Gesture="Ctrl+D0" Command="{Binding ResetFontSizeCommand}" />
    <KeyBinding Gesture="Ctrl+Shift+C" Command="{Binding CopySelectionCommand}" />
    <KeyBinding Gesture="Ctrl+Shift+V" Command="{Binding PasteClipboardCommand}" />
    <KeyBinding Gesture="Ctrl+Shift+A" Command="{Binding SelectAllCommand}" />
    <KeyBinding Gesture="Ctrl+D1" Command="{Binding SwitchToTabByIndexCommand}" CommandParameter="0" />
    <KeyBinding Gesture="Ctrl+D2" Command="{Binding SwitchToTabByIndexCommand}" CommandParameter="1" />
    <KeyBinding Gesture="Ctrl+D3" Command="{Binding SwitchToTabByIndexCommand}" CommandParameter="2" />
    <KeyBinding Gesture="Ctrl+D4" Command="{Binding SwitchToTabByIndexCommand}" CommandParameter="3" />
    <KeyBinding Gesture="Ctrl+D5" Command="{Binding SwitchToTabByIndexCommand}" CommandParameter="4" />
    <KeyBinding Gesture="Ctrl+D6" Command="{Binding SwitchToTabByIndexCommand}" CommandParameter="5" />
    <KeyBinding Gesture="Ctrl+D7" Command="{Binding SwitchToTabByIndexCommand}" CommandParameter="6" />
    <KeyBinding Gesture="Ctrl+D8" Command="{Binding SwitchToTabByIndexCommand}" CommandParameter="7" />
    <KeyBinding Gesture="Ctrl+D9" Command="{Binding SwitchToTabByIndexCommand}" CommandParameter="8" />
  </Window.KeyBindings>

  <Grid>
  <DockPanel>
    <Border DockPanel.Dock="Top"
            Background="{DynamicResource ToolbarBackgroundBrush}"
            Padding="4,2"
            ClipToBounds="True">
      <Grid ColumnDefinitions="Auto,*"
            ColumnSpacing="8"
            ClipToBounds="True">
        <StackPanel Grid.Column="0"
                    Orientation="Horizontal"
                    Spacing="4"
                    VerticalAlignment="Center">
          <Button Content="+ New Tab" Height="24"
                  FontSize="11" Padding="8,2"
                  Command="{Binding NewTabCommand}"
                  ToolTip.Tip="New terminal tab (Ctrl+T)" />
        </StackPanel>

        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="4"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    ClipToBounds="True">
          <Button Content="A-" Width="28" Height="24"
                  FontSize="10" Padding="2"
                  Command="{Binding DecreaseFontSizeCommand}"
                  ToolTip.Tip="Decrease font size (Ctrl+-)" />
          <TextBlock Text="{Binding FontSizeDisplay}" VerticalAlignment="Center"
                     Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" Width="24"
                     TextAlignment="Center" />
          <Button Content="A+" Width="28" Height="24"
                  FontSize="10" Padding="2"
                  Command="{Binding IncreaseFontSizeCommand}"
                  ToolTip.Tip="Increase font size (Ctrl++)" />
          <Border Width="1" Background="{StaticResource ToolbarDividerBrush}" Margin="4,2" />
          <Button Content="{Binding ThemePresetButtonText}" Height="24"
                  FontSize="10" Padding="8,2"
                  Command="{Binding CycleThemePresetCommand}"
                  ToolTip.Tip="Cycle predefined terminal themes for the active mode" />
          <Button Content="Generate Theme" Height="24"
                  FontSize="10" Padding="8,2"
                  Command="{Binding GenerateThemeCommand}"
                  ToolTip.Tip="Generate a new mode-specific terminal theme for the active mode" />
          <Button Content="Settings" Height="24"
                  FontSize="10" Padding="8,2"
                  Command="{Binding PrepareSettingsPanelCommand}"
                  ToolTip.Tip="Open tabbed terminal settings flyout">
            <Button.Flyout>
              <Flyout Placement="BottomEdgeAlignedRight"
                      FlyoutPresenterClasses="settings-popup">
                <settings:TerminalSettingsPanel DataContext="{Binding SettingsPanelState}" />
              </Flyout>
            </Button.Flyout>
          </Button>
          <Border Width="1" Background="{StaticResource ToolbarDividerBrush}" Margin="4,2" />
          <Button Content="{Binding ModeButtonText}" Height="24"
                  FontSize="10" Padding="8,2"
                  Command="{Binding CycleRenderModeCommand}"
                  ToolTip.Tip="Switch rendering mode (Native VT / Managed VT / Rendered)" />
          <ToggleButton Content="{Binding SixelButtonText}" Height="24"
                        FontSize="10" Padding="8,2"
                        IsChecked="{Binding SixelGraphicsEnabled}"
                        ToolTip.Tip="Enable or disable sixel graphics for terminal tabs" />
          <Button Content="{Binding ShaderSampleButtonText}" Height="24"
                  FontSize="10" Padding="8,2"
                  Command="{Binding CycleShaderSampleCommand}"
                  ToolTip.Tip="Cycle terminal framebuffer shader samples" />
          <Border Width="1" Background="{StaticResource ToolbarDividerBrush}" Margin="4,2" />
          <Button Content="{Binding CaptureToggleButtonText}" Height="24"
                  FontSize="10" Padding="8,2"
                  Command="{Binding ToggleCaptureCommand}"
                  ToolTip.Tip="Start or stop capture for the active standalone terminal tab" />
          <ComboBox Width="132"
                    Height="24"
                    FontSize="10"
                    ItemsSource="{Binding CaptureFormats}"
                    SelectedItem="{Binding SelectedCaptureFormat}"
                    ToolTip.Tip="Recording file format used when saving captures">
            <ComboBox.ItemTemplate>
              <DataTemplate x:DataType="vm:TerminalCaptureFormatOption">
                <TextBlock Text="{Binding DisplayName}" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
          <Button Content="Save Capture" Height="24"
                  FontSize="10" Padding="8,2"
                  IsEnabled="{Binding CanSaveCapture}"
                  Command="{Binding SaveCaptureCommand}"
                  ToolTip.Tip="Save the active tab capture to a file" />
          <Button Content="Load Replay" Height="24"
                  FontSize="10" Padding="8,2"
                  Command="{Binding LoadReplayCommand}"
                  ToolTip.Tip="Load a capture file and open a replay tab" />
        </StackPanel>
      </Grid>
    </Border>

    <Border DockPanel.Dock="Top"
            Background="{DynamicResource ToolbarBackgroundBrush}"
            BorderBrush="{StaticResource ToolbarDividerBrush}"
            BorderThickness="0,0,0,1"
            Padding="6,4"
            ClipToBounds="True">
      <Grid ColumnDefinitions="*,Auto"
            ColumnSpacing="8"
            ClipToBounds="True">
        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="4"
                    VerticalAlignment="Center">
          <CheckBox Content="Preserve History"
                    Height="24"
                    FontSize="10"
                    IsChecked="{Binding PreserveScrollbackOnRestart}"
                    VerticalAlignment="Center"
                    ToolTip.Tip="Preserve terminal history when restarting the active session" />
          <Button Content="Restart Session"
                  Height="24"
                  FontSize="10"
                  Padding="8,2"
                  Command="{Binding RestartActiveSessionCommand}"
                  ToolTip.Tip="Restart the active terminal session" />
          <Button x:Name="ClearHistoryButton"
                  Content="Clear History"
                  Height="24"
                  FontSize="10"
                  Padding="8,2"
                  Command="{Binding ClearActiveScrollbackCommand}"
                  ToolTip.Tip="Clear visible history on the active terminal tab" />
          <Button Content="Hyperlink Sample"
                  Height="24"
                  FontSize="10"
                  Padding="8,2"
                  Command="{Binding ShowHyperlinkSampleCommand}"
                  ToolTip.Tip="Inject OSC8 hyperlink sample output into the active terminal tab" />
          <Button Content="Kitty Graphics"
                  Height="24"
                  FontSize="10"
                  Padding="8,2"
                  Command="{Binding ShowKittyGraphicsSampleCommand}"
                  ToolTip.Tip="Inject a Ghostty Kitty Graphics sample into the active native VT tab" />
          <Button Content="Copy Plain Snapshot"
                  Height="24"
                  FontSize="10"
                  Padding="8,2"
                  Command="{Binding CopyPlainSnapshotCommand}"
                  ToolTip.Tip="Copy a plain-text snapshot of the active terminal buffer" />
          <Button Content="Copy VT Snapshot"
                  Height="24"
                  FontSize="10"
                  Padding="8,2"
                  Command="{Binding CopyStyledVtSnapshotCommand}"
                  ToolTip.Tip="Copy a styled VT snapshot of the active terminal buffer" />
          <Button Content="Copy HTML Snapshot"
                  Height="24"
                  FontSize="10"
                  Padding="8,2"
                  Command="{Binding CopyHtmlSnapshotCommand}"
                  ToolTip.Tip="Copy an HTML snapshot of the active terminal buffer" />
          <Button Content="{Binding GhosttyDiagnosticsButtonText}"
                  Height="24"
                  FontSize="10"
                  Padding="8,2"
                  Command="{Binding ToggleGhosttyDiagnosticsCommand}"
                  ToolTip.Tip="Show or hide Ghostty VT capability and active-tab diagnostics" />
        </StackPanel>

        <StackPanel Grid.Column="0"
                    Orientation="Horizontal"
                    Spacing="4"
                    VerticalAlignment="Center"
                    ClipToBounds="True">
          <TextBlock Text="Search"
                     Margin="0,4,0,0"
                     Foreground="{DynamicResource ToolbarForegroundBrush}"
                     FontSize="11" />
          <TextBox Width="220"
                   PlaceholderText="Find in active terminal"
                   Text="{Binding SearchQuery}" />
          <Button Content="Find"
                  Height="24"
                  FontSize="10"
                  Padding="8,2"
                  IsEnabled="{Binding CanApplySearch}"
                  Command="{Binding ApplySearchCommand}"
                  ToolTip.Tip="Start search on the active terminal tab" />
          <Button Content="Prev"
                  Height="24"
                  FontSize="10"
                  Padding="8,2"
                  IsEnabled="{Binding CanAdvanceSearch}"
                  Command="{Binding PreviousSearchCommand}"
                  ToolTip.Tip="Select the previous search result" />
          <Button Content="Next"
                  Height="24"
                  FontSize="10"
                  Padding="8,2"
                  IsEnabled="{Binding CanAdvanceSearch}"
                  Command="{Binding NextSearchCommand}"
                  ToolTip.Tip="Select the next search result" />
          <Button Content="Clear"
                  Height="24"
                  FontSize="10"
                  Padding="8,2"
                  IsEnabled="{Binding CanClearSearch}"
                  Command="{Binding ClearSearchCommand}"
                  ToolTip.Tip="Clear search highlights on the active terminal tab" />
          <TextBlock Text="{Binding SearchResultText}"
                     Margin="8,4,0,0"
                     Foreground="{DynamicResource ToolbarForegroundBrush}"
                     FontSize="11" />
        </StackPanel>
      </Grid>
    </Border>

    <Border DockPanel.Dock="Top"
            Background="{DynamicResource ToolbarBackgroundBrush}"
            BorderBrush="{StaticResource ToolbarDividerBrush}"
            BorderThickness="0,0,0,1"
            Padding="6,4"
            IsVisible="{Binding ShowGhosttyDiagnostics}">
      <StackPanel Spacing="4">
        <TextBlock Text="Ghostty VT Diagnostics"
                   Foreground="{DynamicResource ToolbarForegroundBrush}"
                   FontSize="11" />
        <TextBox Height="132"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 Text="{Binding GhosttyDiagnosticsText}" />
      </StackPanel>
    </Border>

    <Border DockPanel.Dock="Top"
            Background="{DynamicResource ToolbarBackgroundBrush}"
            BorderBrush="{StaticResource ToolbarDividerBrush}"
            BorderThickness="0,0,0,1"
            Padding="6,4"
            IsVisible="{Binding ShowSessionTransportPicker}">
      <StackPanel Spacing="6">
        <WrapPanel Orientation="Horizontal">
          <TextBlock Text="Category" Margin="0,4,6,0"
                     Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" />
          <ComboBox Width="150" Margin="0,0,8,0"
                    ItemsSource="{Binding SettingsCategories}"
                    SelectedItem="{Binding SelectedSettingsCategory}">
            <ComboBox.ItemTemplate>
              <DataTemplate x:DataType="vm:SettingsCategoryOption">
                <TextBlock Text="{Binding DisplayName}" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>

          <TextBlock Text="Session" Margin="0,4,6,0"
                     Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" />
          <TextBox Width="150" Margin="0,0,8,0"
                   Text="{Binding SessionName}" />

          <TextBlock Text="Transport" Margin="0,4,6,0"
                     Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" />
          <ComboBox Width="130" Margin="0,0,8,0"
                    ItemsSource="{Binding TransportModes}"
                    SelectedItem="{Binding SelectedTransportMode}">
            <ComboBox.ItemTemplate>
              <DataTemplate x:DataType="vm:TransportModeOption">
                <TextBlock Text="{Binding DisplayName}" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
        </WrapPanel>

        <TextBlock Text="Transport settings are used for all demo tabs."
                   Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11"
                   IsVisible="{Binding ShowSessionTransportHint}" />

        <StackPanel Spacing="4" IsVisible="{Binding ShowSessionSettingsCategory}">
          <TextBlock Text="Session defaults for new tabs."
                     Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" />
          <WrapPanel Orientation="Horizontal">
            <TextBlock Text="Name" Margin="0,4,6,0"
                       Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" />
            <TextBox Width="180" Margin="0,0,8,0"
                     Text="{Binding SessionName}" />
            <TextBlock Text="Active Transport" Margin="0,4,6,0"
                       Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" />
            <TextBlock Margin="0,4,0,0"
                       Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11"
                       Text="{Binding SelectedTransportMode.DisplayName}" />
          </WrapPanel>
        </StackPanel>

        <StackPanel Spacing="4" IsVisible="{Binding ShowConnectionSettingsCategory}">
          <WrapPanel Orientation="Horizontal" IsVisible="{Binding IsPtyTransportSelected}">
            <TextBlock Text="Shell" Margin="0,4,6,0"
                       Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" />
            <ComboBox Width="240" Margin="0,0,8,0"
                      ItemsSource="{Binding ShellProfiles}"
                      SelectedItem="{Binding SelectedShellProfile}">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="vm:ShellProfileOption">
                  <TextBlock Text="{Binding DisplayName}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBlock Text="Working Dir" Margin="0,4,6,0"
                       Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" />
            <TextBox Width="280" Margin="0,0,8,0"
                     Text="{Binding WorkingDirectory}" />
          </WrapPanel>

          <WrapPanel Orientation="Horizontal" IsVisible="{Binding IsPipeTransportSelected}">
            <TextBlock Text="Working Dir" Margin="0,4,6,0"
                       Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" />
            <TextBox Width="240" Margin="0,0,8,0"
                     Text="{Binding WorkingDirectory}" />
            <TextBlock Text="Pipe Cmd" Margin="0,4,6,0"
                       Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" />
            <TextBox Width="280" Margin="0,0,8,0"
                     Text="{Binding PipeCommandText}" />
            <CheckBox Content="Merge stderr"
                      Margin="0,2,8,0"
                      IsChecked="{Binding PipeMergeStdErrIntoStdOut}" />
          </WrapPanel>

          <WrapPanel Orientation="Horizontal" IsVisible="{Binding IsRawTcpTransportSelected}">
            <TextBlock Text="Host" Margin="0,4,6,0"
                       Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" />
            <TextBox Width="180" Margin="0,0,8,0"
                     Text="{Binding RawTcpHost}" />
            <TextBlock Text="Port" Margin="0,4,6,0"
                       Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" />
            <TextBox Width="80" Margin="0,0,8,0"
                     Text="{Binding RawTcpPort}" />
          </WrapPanel>

          <WrapPanel Orientation="Horizontal" IsVisible="{Binding IsTelnetTransportSelected}">
            <TextBlock Text="Host" Margin="0,4,6,0"
                       Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" />
            <TextBox Width="180" Margin="0,0,8,0"
                     Text="{Binding TelnetHost}" />
            <TextBlock Text="Port" Margin="0,4,6,0"
                       Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" />
            <TextBox Width="80" Margin="0,0,8,0"
                     Text="{Binding TelnetPort}" />
          </WrapPanel>

          <WrapPanel Orientation="Horizontal" IsVisible="{Binding IsSerialTransportSelected}">
            <TextBlock Text="Port" Margin="0,4,6,0"
                       Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" />
            <TextBox Width="120" Margin="0,0,8,0"
                     Text="{Binding SerialPortName}" />
            <TextBlock Text="Baud" Margin="0,4,6,0"
                       Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" />
            <TextBox Width="90" Margin="0,0,8,0"
                     Text="{Binding SerialBaudRate}" />
            <TextBlock Text="Data Bits" Margin="0,4,6,0"
                       Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" />
            <TextBox Width="70" Margin="0,0,8,0"
                     Text="{Binding SerialDataBits}" />
            <TextBlock Text="Parity" Margin="0,4,6,0"
                       Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" />
            <ComboBox Width="120" Margin="0,0,8,0"
                      ItemsSource="{Binding SerialParityOptions}"
                      SelectedItem="{Binding SelectedSerialParity}" />
            <TextBlock Text="Stop Bits" Margin="0,4,6,0"
                       Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" />
            <ComboBox Width="120" Margin="0,0,8,0"
                      ItemsSource="{Binding SerialStopBitsOptions}"
                      SelectedItem="{Binding SelectedSerialStopBits}" />
            <TextBlock Text="Handshake" Margin="0,4,6,0"
                       Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" />
            <ComboBox Width="170" Margin="0,0,8,0"
                      ItemsSource="{Binding SerialHandshakeOptions}"
                      SelectedItem="{Binding SelectedSerialHandshake}" />
            <TextBlock Text="NewLine" Margin="0,4,6,0"
                       Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" />
            <TextBox Width="80" Margin="0,0,8,0"
                     Text="{Binding SerialNewLine}" />
          </WrapPanel>

          <WrapPanel Orientation="Horizontal" IsVisible="{Binding IsSshTransportSelected}">
            <TextBlock Text="Host" Margin="0,4,6,0"
                       Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" />
            <TextBox Width="180" Margin="0,0,8,0" Text="{Binding SshHost}" />
            <TextBlock Text="Port" Margin="0,4,6,0"
                       Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" />
            <TextBox Width="80" Margin="0,0,8,0" Text="{Binding SshPort}" />
            <TextBlock Text="User" Margin="0,4,6,0"
                       Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" />
            <TextBox Width="140" Margin="0,0,8,0" Text="{Binding SshUsername}" />
          </WrapPanel>
        </StackPanel>

        <StackPanel Spacing="4" IsVisible="{Binding ShowTerminalSettingsCategory}">
          <WrapPanel Orientation="Horizontal">
            <CheckBox Content="Copy on Select"
                      Margin="0,2,8,0"
                      IsChecked="{Binding CopyOnSelectEnabled}" />
            <CheckBox Content="Bell Notifications"
                      Margin="0,2,8,0"
                      IsChecked="{Binding EnableBellNotifications}" />
            <CheckBox Content="Backspace sends Ctrl-H"
                      Margin="0,2,8,0"
                      IsChecked="{Binding BackspaceSendsControlH}" />
          </WrapPanel>
          <WrapPanel Orientation="Horizontal">
            <CheckBox Content="Enable Text Shaping"
                      Margin="0,2,8,0"
                      IsChecked="{Binding EnableTextShaping}" />
            <CheckBox Content="Reflow on Resize"
                      Margin="0,2,8,0"
                      IsChecked="{Binding ReflowOnResize}" />
            <CheckBox Content="Sixel Graphics"
                      Margin="0,2,8,0"
                      IsChecked="{Binding SixelGraphicsEnabled}" />
            <CheckBox Content="Enable Ligatures"
                      Margin="0,2,8,0"
                      IsChecked="{Binding EnableLigatures}" />
            <TextBlock Text="Paste Safety" Margin="0,4,6,0"
                       Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" />
            <ComboBox Width="220" Margin="0,0,8,0"
                      ItemsSource="{Binding PasteSafetyPolicies}"
                      SelectedItem="{Binding SelectedPasteSafetyPolicy}" />
          </WrapPanel>
          <WrapPanel Orientation="Horizontal" IsVisible="{Binding ShowTerminalSshFields}">
            <CheckBox Content="Request PTY"
                      Margin="0,2,8,0"
                      IsChecked="{Binding SshRequestPty}" />
            <TextBlock Text="Terminal" Margin="0,4,6,0"
                       Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" />
            <TextBox Width="140" Margin="0,0,8,0" Text="{Binding SshTerminalType}" />
            <TextBlock Text="Initial Cmd" Margin="0,4,6,0"
                       Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" />
            <TextBox Width="260" Margin="0,0,8,0" Text="{Binding SshInitialCommand}" />
          </WrapPanel>

          <WrapPanel Orientation="Horizontal" IsVisible="{Binding ShowTerminalTelnetFields}">
            <TextBlock Text="Terminal" Margin="0,4,6,0"
                       Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" />
            <TextBox Width="140" Margin="0,0,8,0" Text="{Binding TelnetTerminalType}" />
            <TextBlock Text="Initial Cmd" Margin="0,4,6,0"
                       Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" />
            <TextBox Width="260" Margin="0,0,8,0" Text="{Binding TelnetInitialCommand}" />
          </WrapPanel>

          <TextBlock Text="No protocol-specific terminal options are available for the selected transport."
                     Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11"
                     IsVisible="{Binding ShowTerminalSettingsHint}" />
        </StackPanel>

        <StackPanel Spacing="4" IsVisible="{Binding ShowAppearanceSettingsCategory}">
          <WrapPanel Orientation="Horizontal">
            <TextBlock Text="Font Size" Margin="0,4,6,0"
                       Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" />
            <Button Content="A-" Width="28" Height="24"
                    FontSize="10" Padding="2"
                    Command="{Binding DecreaseFontSizeCommand}" />
            <TextBlock Text="{Binding FontSizeDisplay}" Margin="6,4,6,0"
                       Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" />
            <Button Content="A+" Width="28" Height="24"
                    FontSize="10" Padding="2"
                    Command="{Binding IncreaseFontSizeCommand}" />
            <Button Content="Reset" Height="24"
                    FontSize="10" Padding="8,2" Margin="8,0,0,0"
                    Command="{Binding ResetFontSizeCommand}" />
          </WrapPanel>
          <WrapPanel Orientation="Horizontal">
            <Button Content="{Binding ThemePresetButtonText}" Height="24"
                    FontSize="10" Padding="8,2"
                    Command="{Binding CycleThemePresetCommand}" />
            <Button Content="Generate Theme" Height="24"
                    FontSize="10" Padding="8,2" Margin="8,0,0,0"
                    Command="{Binding GenerateThemeCommand}" />
          </WrapPanel>
        </StackPanel>

        <StackPanel Spacing="4" IsVisible="{Binding ShowSshSettingsCategory}">
          <TextBlock Text="Select SSH transport in Connection to configure SSH-specific settings."
                     Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11"
                     IsVisible="{Binding ShowSshSettingsUnavailableHint}" />

          <StackPanel Spacing="4" IsVisible="{Binding ShowSshSettingsFields}">
            <WrapPanel Orientation="Horizontal">
              <TextBlock Text="Auth" Margin="0,4,6,0"
                         Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" />
              <ComboBox Width="150" Margin="0,0,8,0"
                        ItemsSource="{Binding SshAuthModes}"
                        SelectedItem="{Binding SelectedSshAuthMode}">
                <ComboBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:SshAuthModeOption">
                    <TextBlock Text="{Binding DisplayName}" />
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>

              <TextBlock Text="Password" Margin="0,4,6,0"
                         Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11"
                         IsVisible="{Binding ShowSshPasswordField}" />
              <TextBox Width="140" Margin="0,0,8,0"
                       Text="{Binding SshPassword}"
                       PasswordChar="*"
                       IsVisible="{Binding ShowSshPasswordField}" />

              <TextBlock Text="Private Key(s)" Margin="0,4,6,0"
                         Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11"
                         IsVisible="{Binding ShowSshPrivateKeyField}" />
              <TextBox Width="220" Margin="0,0,8,0"
                       Text="{Binding SshPrivateKeyPath}"
                       PlaceholderText="Path or PEM; separate multiple with comma/semicolon/newline"
                       IsVisible="{Binding ShowSshPrivateKeyField}" />

              <TextBlock Text="Agent credentials are resolved from your SSH agent socket."
                         Margin="0,4,8,0"
                         Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11"
                         IsVisible="{Binding ShowSshAgentHint}" />
            </WrapPanel>

            <WrapPanel Orientation="Horizontal">
              <TextBlock Text="Host Key SHA256 (optional pin)" Margin="0,4,6,0"
                         Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" />
              <TextBox Width="240" Margin="0,0,8,0" Text="{Binding SshExpectedHostKeyFingerprintSha256}" />
            </WrapPanel>

            <WrapPanel Orientation="Horizontal">
              <TextBlock Text="Proxy" Margin="0,4,6,0"
                         Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" />
              <ComboBox Width="120" Margin="0,0,8,0"
                        ItemsSource="{Binding SshProxyTypes}"
                        SelectedItem="{Binding SelectedSshProxyType}" />
              <TextBlock Text="Host" Margin="0,4,6,0"
                         Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11"
                         IsVisible="{Binding ShowSshProxyFields}" />
              <TextBox Width="160" Margin="0,0,8,0"
                       Text="{Binding SshProxyHost}"
                       IsVisible="{Binding ShowSshProxyFields}" />
              <TextBlock Text="Port" Margin="0,4,6,0"
                         Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11"
                         IsVisible="{Binding ShowSshProxyFields}" />
              <TextBox Width="80" Margin="0,0,8,0"
                       Text="{Binding SshProxyPort}"
                       IsVisible="{Binding ShowSshProxyFields}" />
              <TextBlock Text="User" Margin="0,4,6,0"
                         Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11"
                         IsVisible="{Binding ShowSshProxyFields}" />
              <TextBox Width="120" Margin="0,0,8,0"
                       Text="{Binding SshProxyUsername}"
                       IsVisible="{Binding ShowSshProxyFields}" />
              <TextBlock Text="Password" Margin="0,4,6,0"
                         Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11"
                         IsVisible="{Binding ShowSshProxyFields}" />
              <TextBox Width="120" Margin="0,0,8,0"
                       Text="{Binding SshProxyPassword}"
                       PasswordChar="*"
                       IsVisible="{Binding ShowSshProxyFields}" />
            </WrapPanel>

            <WrapPanel Orientation="Horizontal">
              <CheckBox Content="Local Port Forward"
                        Margin="0,2,8,0"
                        IsChecked="{Binding SshLocalPortForwardEnabled}" />
              <TextBlock Text="Bind" Margin="0,4,6,0"
                         Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11"
                         IsVisible="{Binding ShowSshPortForwardFields}" />
              <TextBox Width="120" Margin="0,0,8,0"
                       Text="{Binding SshLocalPortForwardBindAddress}"
                       IsVisible="{Binding ShowSshPortForwardFields}" />
              <TextBlock Text="Source" Margin="0,4,6,0"
                         Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11"
                         IsVisible="{Binding ShowSshPortForwardFields}" />
              <TextBox Width="80" Margin="0,0,8,0"
                       Text="{Binding SshLocalPortForwardSourcePort}"
                       IsVisible="{Binding ShowSshPortForwardFields}" />
              <TextBlock Text="Destination Host" Margin="0,4,6,0"
                         Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11"
                         IsVisible="{Binding ShowSshPortForwardFields}" />
              <TextBox Width="160" Margin="0,0,8,0"
                       Text="{Binding SshLocalPortForwardDestinationHost}"
                       IsVisible="{Binding ShowSshPortForwardFields}" />
              <TextBlock Text="Destination Port" Margin="0,4,6,0"
                         Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11"
                         IsVisible="{Binding ShowSshPortForwardFields}" />
              <TextBox Width="80" Margin="0,0,8,0"
                       Text="{Binding SshLocalPortForwardDestinationPort}"
                       IsVisible="{Binding ShowSshPortForwardFields}" />
            </WrapPanel>

            <WrapPanel Orientation="Horizontal">
              <CheckBox Content="Enable X11"
                        Margin="0,2,8,0"
                        IsChecked="{Binding SshX11Enabled}" />
              <TextBlock Text="Display" Margin="0,4,6,0"
                         Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11"
                         IsVisible="{Binding ShowSshX11DisplayField}" />
              <TextBox Width="100" Margin="0,0,8,0"
                       Text="{Binding SshX11Display}"
                       IsVisible="{Binding ShowSshX11DisplayField}" />
              <TextBlock Text="KeepAlive (s)" Margin="0,4,6,0"
                         Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" />
              <TextBox Width="90" Margin="0,0,8,0"
                       Text="{Binding SshKeepAliveIntervalSeconds}" />
              <TextBlock Text="Connect Timeout (s)" Margin="0,4,6,0"
                         Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" />
              <TextBox Width="90" Margin="0,0,8,0"
                       Text="{Binding SshConnectTimeoutSeconds}" />
            </WrapPanel>
          </StackPanel>
        </StackPanel>

        <StackPanel Spacing="4" IsVisible="{Binding ShowLoggingSettingsCategory}">
          <WrapPanel Orientation="Horizontal">
            <CheckBox Content="Enable Session Log"
                      Margin="0,2,8,0"
                      IsChecked="{Binding SessionLoggingEnabled}" />
            <TextBlock Text="Format" Margin="0,4,6,0"
                       Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" />
            <ComboBox Width="140" Margin="0,0,8,0"
                      ItemsSource="{Binding SessionLogFormats}"
                      SelectedItem="{Binding SelectedSessionLogFormat}" />
            <CheckBox Content="Flush Frequently"
                      Margin="0,2,8,0"
                      IsChecked="{Binding SessionLogFlushFrequently}" />
            <CheckBox Content="Enable Event Log"
                      Margin="0,2,8,0"
                      IsChecked="{Binding EventLogEnabled}" />
            <Button Content="Clear Event Log"
                    Height="24"
                    FontSize="10"
                    Padding="8,2"
                    Command="{Binding ClearEventLogCommand}"
                    IsEnabled="{Binding HasEventLogEntries}" />
            <TextBlock Margin="8,4,0,0"
                       Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11"
                       Text="{Binding EventLogEntryCountText}" />
          </WrapPanel>
          <WrapPanel Orientation="Horizontal">
            <TextBlock Text="Session Log File" Margin="0,4,6,0"
                       Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" />
            <TextBox Width="620" Margin="0,0,8,0"
                     Text="{Binding SessionLogFilePath}" />
          </WrapPanel>
          <TextBlock Text="Event timeline for connection lifecycle and runtime notifications."
                     Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" />
          <TextBox Height="140"
                   IsReadOnly="True"
                   AcceptsReturn="True"
                   TextWrapping="Wrap"
                   Text="{Binding EventLogText}" />
        </StackPanel>
      </StackPanel>
    </Border>

    <Border DockPanel.Dock="Top"
            Background="{DynamicResource ToolbarBackgroundBrush}"
            BorderBrush="{StaticResource ToolbarDividerBrush}"
            BorderThickness="0,0,0,1"
            Padding="6,4"
            IsVisible="{Binding IsReplayEnabled}">
      <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
        <TextBlock Text="Replay" Margin="0,4,0,0"
                   Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" />
        <Button Content="{Binding ReplayPlayPauseButtonText}" Height="24"
                FontSize="10" Padding="8,2"
                IsEnabled="{Binding CanReplayControl}"
                Command="{Binding ToggleReplayPlaybackCommand}" />
        <Button Content="Stop" Height="24"
                FontSize="10" Padding="8,2"
                IsEnabled="{Binding CanReplayControl}"
                Command="{Binding StopReplayCommand}" />
        <Slider Width="340"
                Minimum="0"
                Maximum="{Binding ReplayDurationSeconds}"
                Value="{Binding ReplayTimelineValue, Mode=TwoWay}"
                IsEnabled="{Binding CanSeekReplay}" />
        <TextBlock Text="{Binding ReplayTimelineText}"
                   Margin="0,4,0,0"
                   Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" />
        <TextBlock Text="{Binding ReplaySourceLabel}"
                   Margin="8,4,0,0"
                   Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" />
      </StackPanel>
    </Border>

    <Border DockPanel.Dock="Top" Background="{DynamicResource TabStripBackgroundBrush}" Padding="4,2,4,0">
      <StackPanel Name="TabStrip" Orientation="Horizontal" Spacing="2" />
    </Border>

    <Border DockPanel.Dock="Bottom" Background="{DynamicResource StatusBarBackgroundBrush}" Padding="8,2" Height="24">
      <DockPanel>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8">
          <TextBlock Text="{Binding TextRenderPipelineIndicatorText}"
                     Foreground="{DynamicResource StatusBarForegroundBrush}" FontSize="11"
                     VerticalAlignment="Center" />
          <Border Width="1" Height="12" Background="{DynamicResource StatusBarForegroundBrush}" Opacity="0.35" />
          <TextBlock Text="{Binding DimensionsText}"
                     Foreground="{DynamicResource StatusBarForegroundBrush}" FontSize="11"
                     VerticalAlignment="Center" />
        </StackPanel>
        <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource StatusBarForegroundBrush}"
                   FontSize="11" VerticalAlignment="Center" />
      </DockPanel>
    </Border>

    <Grid Name="TerminalHost" />
  </DockPanel>

  <Border Background="#99000000"
          IsVisible="{Binding IsSshHostKeyPromptVisible}">
    <Border HorizontalAlignment="Stretch"
            VerticalAlignment="Center"
            MaxWidth="560"
            Margin="16"
            Background="{DynamicResource WindowBackgroundBrush}"
            BorderBrush="{StaticResource ToolbarDividerBrush}"
            BorderThickness="1"
            CornerRadius="6"
            Padding="20">
      <StackPanel Spacing="12">
        <TextBlock Text="{Binding SshHostKeyPromptTitle}"
                   Foreground="{DynamicResource ToolbarForegroundBrush}"
                   FontSize="18"
                   FontWeight="SemiBold" />
        <TextBlock Text="{Binding SshHostKeyPromptEndpoint}"
                   Foreground="{DynamicResource ToolbarForegroundBrush}"
                   FontSize="12" />

        <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0"
                     Text="Algorithm"
                     Foreground="{DynamicResource ToolbarForegroundBrush}"
                     FontSize="12" />
          <TextBlock Grid.Row="0" Grid.Column="1"
                     Text="{Binding SshHostKeyPromptAlgorithm}"
                     Foreground="{DynamicResource ToolbarForegroundBrush}"
                     FontSize="12" />
          <TextBlock Grid.Row="1" Grid.Column="0"
                     Text="SHA256"
                     Foreground="{DynamicResource ToolbarForegroundBrush}"
                     FontSize="12" />
          <TextBox Grid.Row="1" Grid.Column="1"
                   Text="{Binding SshHostKeyPromptFingerprintSha256, Mode=OneWay}"
                   IsReadOnly="True"
                   FontFamily="Consolas"
                   FontSize="12" />
          <TextBlock Grid.Row="2" Grid.Column="0"
                     Text="MD5"
                     Foreground="{DynamicResource ToolbarForegroundBrush}"
                     FontSize="12" />
          <TextBox Grid.Row="2" Grid.Column="1"
                   Text="{Binding SshHostKeyPromptFingerprintMd5, Mode=OneWay}"
                   IsReadOnly="True"
                   FontFamily="Consolas"
                   FontSize="12" />
        </Grid>

        <TextBlock Text="{Binding SshHostKeyPromptPersistenceText}"
                   Foreground="{DynamicResource ToolbarForegroundBrush}"
                   FontSize="12"
                   TextWrapping="Wrap" />

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">
          <Button Content="Decline"
                  MinWidth="84"
                  Command="{Binding DeclineSshHostKeyCommand}" />
          <Button Content="Accept"
                  MinWidth="84"
                  Command="{Binding AcceptSshHostKeyCommand}" />
        </StackPanel>
      </StackPanel>
    </Border>
  </Border>
  </Grid>

  <Window.ContextMenu>
    <ContextMenu x:DataType="vm:MainWindowViewModel"
                 DataContext="{Binding #RootWindow.DataContext}">
      <MenuItem Header="_Copy" InputGesture="Ctrl+Shift+C" Command="{Binding CopySelectionCommand}" />
      <MenuItem Header="_Paste" InputGesture="Ctrl+Shift+V" Command="{Binding PasteClipboardCommand}" />
      <Separator />
      <MenuItem Header="Select _All" InputGesture="Ctrl+Shift+A" Command="{Binding SelectAllCommand}" />
      <Separator />
      <MenuItem Header="_New Tab" InputGesture="Ctrl+T" Command="{Binding NewTabCommand}" />
      <MenuItem Header="C_lose Tab" InputGesture="Ctrl+W" Command="{Binding CloseCurrentTabCommand}" />
    </ContextMenu>
  </Window.ContextMenu>

</Window>
