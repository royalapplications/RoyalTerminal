<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RoyalTerminal.Demo.ViewModels"
        x:Class="RoyalTerminal.Demo.MainWindow"
        x:Name="RootWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="RoyalTerminal Terminal"
        Width="1024" Height="768"
        MinWidth="400" MinHeight="300"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+T" Command="{Binding NewTabCommand}" />
        <KeyBinding Gesture="Ctrl+W" Command="{Binding CloseCurrentTabCommand}" />
        <KeyBinding Gesture="Ctrl+Tab" Command="{Binding CycleTabForwardCommand}" />
        <KeyBinding Gesture="Ctrl+Shift+Tab" Command="{Binding CycleTabBackwardCommand}" />
        <KeyBinding Gesture="Ctrl+Add" Command="{Binding IncreaseFontSizeCommand}" />
        <KeyBinding Gesture="Ctrl+OemPlus" Command="{Binding IncreaseFontSizeCommand}" />
        <KeyBinding Gesture="Ctrl+Subtract" Command="{Binding DecreaseFontSizeCommand}" />
        <KeyBinding Gesture="Ctrl+OemMinus" Command="{Binding DecreaseFontSizeCommand}" />
        <KeyBinding Gesture="Ctrl+D0" Command="{Binding ResetFontSizeCommand}" />
        <KeyBinding Gesture="Ctrl+Shift+R" Command="{Binding ToggleRenderedBackendCommand}" />
        <KeyBinding Gesture="Ctrl+Shift+C" Command="{Binding CopySelectionCommand}" />
        <KeyBinding Gesture="Ctrl+Shift+V" Command="{Binding PasteClipboardCommand}" />
        <KeyBinding Gesture="Ctrl+D1" Command="{Binding SwitchToTabByIndexCommand}" CommandParameter="0" />
        <KeyBinding Gesture="Ctrl+D2" Command="{Binding SwitchToTabByIndexCommand}" CommandParameter="1" />
        <KeyBinding Gesture="Ctrl+D3" Command="{Binding SwitchToTabByIndexCommand}" CommandParameter="2" />
        <KeyBinding Gesture="Ctrl+D4" Command="{Binding SwitchToTabByIndexCommand}" CommandParameter="3" />
        <KeyBinding Gesture="Ctrl+D5" Command="{Binding SwitchToTabByIndexCommand}" CommandParameter="4" />
        <KeyBinding Gesture="Ctrl+D6" Command="{Binding SwitchToTabByIndexCommand}" CommandParameter="5" />
        <KeyBinding Gesture="Ctrl+D7" Command="{Binding SwitchToTabByIndexCommand}" CommandParameter="6" />
        <KeyBinding Gesture="Ctrl+D8" Command="{Binding SwitchToTabByIndexCommand}" CommandParameter="7" />
        <KeyBinding Gesture="Ctrl+D9" Command="{Binding SwitchToTabByIndexCommand}" CommandParameter="8" />
    </Window.KeyBindings>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="{DynamicResource ToolbarBackgroundBrush}" Padding="4,2">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="4"
                            VerticalAlignment="Center">
                    <Button Content="A-" Width="28" Height="24"
                            FontSize="10" Padding="2"
                            Command="{Binding DecreaseFontSizeCommand}"
                            ToolTip.Tip="Decrease font size (Ctrl+-)" />
                    <TextBlock Text="{Binding FontSizeDisplay}" VerticalAlignment="Center"
                               Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" Width="24"
                               TextAlignment="Center" />
                    <Button Content="A+" Width="28" Height="24"
                            FontSize="10" Padding="2"
                            Command="{Binding IncreaseFontSizeCommand}"
                            ToolTip.Tip="Increase font size (Ctrl++)" />
                    <Border Width="1" Background="{StaticResource ToolbarDividerBrush}" Margin="4,2" />
                    <Button Content="{Binding ThemePresetButtonText}" Height="24"
                            FontSize="10" Padding="8,2"
                            Command="{Binding CycleThemePresetCommand}"
                            ToolTip.Tip="Cycle predefined terminal themes for the active mode" />
                    <Button Content="Generate Theme" Height="24"
                            FontSize="10" Padding="8,2"
                            Command="{Binding GenerateThemeCommand}"
                            ToolTip.Tip="Generate a new mode-specific terminal theme for the active mode" />
                    <Border Width="1" Background="{StaticResource ToolbarDividerBrush}" Margin="4,2" />
                    <Button Content="{Binding ModeButtonText}" Height="24"
                            FontSize="10" Padding="8,2"
                            Command="{Binding CycleRenderModeCommand}"
                            ToolTip.Tip="Switch rendering mode (Ghostty Rendered / Ghostty Native / Native VT / Managed VT / Rendered)" />
                    <Button Content="{Binding RenderedBackendButtonText}" Height="24"
                            FontSize="10" Padding="8,2"
                            Command="{Binding ToggleRenderedBackendCommand}"
                            ToolTip.Tip="Toggle Ghostty rendered backend (TextureInterop / CPU Cell Renderer)" />
                    <Border Width="1" Background="{StaticResource ToolbarDividerBrush}" Margin="4,2" />
                    <Button Content="{Binding CaptureToggleButtonText}" Height="24"
                            FontSize="10" Padding="8,2"
                            Command="{Binding ToggleCaptureCommand}"
                            ToolTip.Tip="Start or stop capture for the active standalone terminal tab" />
                    <Button Content="Save Capture" Height="24"
                            FontSize="10" Padding="8,2"
                            IsEnabled="{Binding CanSaveCapture}"
                            Command="{Binding SaveCaptureCommand}"
                            ToolTip.Tip="Save the active tab capture to a file" />
                    <Button Content="Load Replay" Height="24"
                            FontSize="10" Padding="8,2"
                            Command="{Binding LoadReplayCommand}"
                            ToolTip.Tip="Load a capture file and open a replay tab" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <Button Content="+ New Tab" Height="24"
                            FontSize="11" Padding="8,2"
                            Command="{Binding NewTabCommand}"
                            ToolTip.Tip="New terminal tab (Ctrl+T)" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Border DockPanel.Dock="Top"
                Background="{DynamicResource ToolbarBackgroundBrush}"
                BorderBrush="{StaticResource ToolbarDividerBrush}"
                BorderThickness="0,0,0,1"
                Padding="6,4"
                IsVisible="{Binding ShowSessionTransportPicker}">
            <StackPanel Spacing="4">
                <WrapPanel Orientation="Horizontal">
                    <TextBlock Text="Transport" Margin="0,4,6,0"
                               Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" />
                    <ComboBox Width="120" Margin="0,0,8,0"
                              ItemsSource="{Binding TransportModes}"
                              SelectedItem="{Binding SelectedTransportMode}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:TransportModeOption">
                                <TextBlock Text="{Binding DisplayName}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Text="Shell" Margin="0,4,6,0"
                               Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11"
                               IsVisible="{Binding ShowLocalSessionFields}" />
                    <ComboBox Width="200" Margin="0,0,8,0"
                              ItemsSource="{Binding ShellProfiles}"
                              SelectedItem="{Binding SelectedShellProfile}"
                              IsVisible="{Binding ShowLocalSessionFields}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:ShellProfileOption">
                                <TextBlock Text="{Binding DisplayName}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Text="Working Dir" Margin="0,4,6,0"
                               Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11"
                               IsVisible="{Binding ShowLocalSessionFields}" />
                    <TextBox Width="260" Margin="0,0,8,0"
                             Text="{Binding WorkingDirectory}"
                             IsVisible="{Binding ShowLocalSessionFields}" />

                    <TextBlock Text="Pipe Cmd" Margin="0,4,6,0"
                               Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11"
                               IsVisible="{Binding IsPipeTransportSelected}" />
                    <TextBox Width="280" Margin="0,0,8,0"
                             Text="{Binding PipeCommandText}"
                             IsVisible="{Binding IsPipeTransportSelected}" />
                    <CheckBox Content="Merge stderr"
                              Margin="0,2,8,0"
                              IsChecked="{Binding PipeMergeStdErrIntoStdOut}"
                              IsVisible="{Binding IsPipeTransportSelected}" />
                </WrapPanel>

                <TextBlock Text="Transport settings are shown here. They are used when creating non-Ghostty standalone tabs."
                           Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11"
                           IsVisible="{Binding ShowSessionTransportHint}" />

                <WrapPanel Orientation="Horizontal" IsVisible="{Binding ShowSshSessionFields}">
                    <TextBlock Text="Host" Margin="0,4,6,0"
                               Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" />
                    <TextBox Width="140" Margin="0,0,8,0" Text="{Binding SshHost}" />

                    <TextBlock Text="Port" Margin="0,4,6,0"
                               Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" />
                    <TextBox Width="60" Margin="0,0,8,0" Text="{Binding SshPort}" />

                    <TextBlock Text="User" Margin="0,4,6,0"
                               Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" />
                    <TextBox Width="120" Margin="0,0,8,0" Text="{Binding SshUsername}" />

                    <TextBlock Text="Auth" Margin="0,4,6,0"
                               Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" />
                    <ComboBox Width="150" Margin="0,0,8,0"
                              ItemsSource="{Binding SshAuthModes}"
                              SelectedItem="{Binding SelectedSshAuthMode}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:SshAuthModeOption">
                                <TextBlock Text="{Binding DisplayName}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <CheckBox Content="Request PTY"
                              Margin="0,2,8,0"
                              IsChecked="{Binding SshRequestPty}" />
                </WrapPanel>

                <WrapPanel Orientation="Horizontal" IsVisible="{Binding ShowSshSessionFields}">
                    <TextBlock Text="Password" Margin="0,4,6,0"
                               Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11"
                               IsVisible="{Binding ShowSshPasswordField}" />
                    <TextBox Width="140" Margin="0,0,8,0"
                             Text="{Binding SshPassword}"
                             PasswordChar="*"
                             IsVisible="{Binding ShowSshPasswordField}" />

                    <TextBlock Text="Private Key(s)" Margin="0,4,6,0"
                               Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11"
                               IsVisible="{Binding ShowSshPrivateKeyField}" />
                    <TextBox Width="220" Margin="0,0,8,0"
                             Text="{Binding SshPrivateKeyPath}"
                             Watermark="Path or PEM; separate multiple with comma/semicolon/newline"
                             IsVisible="{Binding ShowSshPrivateKeyField}" />

                    <TextBlock Text="Agent credentials are resolved from your SSH agent socket."
                               Margin="0,4,8,0"
                               Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11"
                               IsVisible="{Binding ShowSshAgentHint}" />

                    <TextBlock Text="Host Key SHA256 (optional pin)" Margin="0,4,6,0"
                               Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" />
                    <TextBox Width="220" Margin="0,0,8,0" Text="{Binding SshExpectedHostKeyFingerprintSha256}" />

                    <TextBlock Text="Terminal" Margin="0,4,6,0"
                               Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" />
                    <TextBox Width="120" Margin="0,0,8,0" Text="{Binding SshTerminalType}" />

                    <TextBlock Text="Initial Cmd" Margin="0,4,6,0"
                               Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" />
                    <TextBox Width="220" Margin="0,0,8,0" Text="{Binding SshInitialCommand}" />
                </WrapPanel>
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Top"
                Background="{DynamicResource ToolbarBackgroundBrush}"
                BorderBrush="{StaticResource ToolbarDividerBrush}"
                BorderThickness="0,0,0,1"
                Padding="6,4"
                IsVisible="{Binding IsReplayEnabled}">
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="Replay" Margin="0,4,0,0"
                           Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" />
                <Button Content="{Binding ReplayPlayPauseButtonText}" Height="24"
                        FontSize="10" Padding="8,2"
                        IsEnabled="{Binding CanReplayControl}"
                        Command="{Binding ToggleReplayPlaybackCommand}" />
                <Button Content="Stop" Height="24"
                        FontSize="10" Padding="8,2"
                        IsEnabled="{Binding CanReplayControl}"
                        Command="{Binding StopReplayCommand}" />
                <Slider Width="340"
                        Minimum="0"
                        Maximum="{Binding ReplayDurationSeconds}"
                        Value="{Binding ReplayTimelineValue, Mode=TwoWay}"
                        IsEnabled="{Binding CanSeekReplay}" />
                <TextBlock Text="{Binding ReplayTimelineText}"
                           Margin="0,4,0,0"
                           Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" />
                <TextBlock Text="{Binding ReplaySourceLabel}"
                           Margin="8,4,0,0"
                           Foreground="{DynamicResource ToolbarForegroundBrush}" FontSize="11" />
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Top" Background="{DynamicResource TabStripBackgroundBrush}" Padding="4,2,4,0">
            <StackPanel Name="TabStrip" Orientation="Horizontal" Spacing="2" />
        </Border>

        <Border DockPanel.Dock="Bottom" Background="{DynamicResource StatusBarBackgroundBrush}" Padding="8,2" Height="24">
            <DockPanel>
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding DimensionsText}"
                           Foreground="{DynamicResource StatusBarForegroundBrush}" FontSize="11"
                           VerticalAlignment="Center" />
                <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource StatusBarForegroundBrush}"
                           FontSize="11" VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <Grid Name="TerminalHost" />
    </DockPanel>

    <Window.ContextMenu>
        <ContextMenu x:DataType="vm:MainWindowViewModel"
                     DataContext="{Binding #RootWindow.DataContext}">
            <MenuItem Header="_Copy" InputGesture="Ctrl+Shift+C" Command="{Binding CopySelectionCommand}" />
            <MenuItem Header="_Paste" InputGesture="Ctrl+Shift+V" Command="{Binding PasteClipboardCommand}" />
            <Separator />
            <MenuItem Header="Select _All" InputGesture="Ctrl+Shift+A" IsEnabled="False" />
            <Separator />
            <MenuItem Header="_New Tab" InputGesture="Ctrl+T" Command="{Binding NewTabCommand}" />
            <MenuItem Header="C_lose Tab" InputGesture="Ctrl+W" Command="{Binding CloseCurrentTabCommand}" />
        </ContextMenu>
    </Window.ContextMenu>

</Window>
